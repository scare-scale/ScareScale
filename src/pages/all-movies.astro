---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import PageHeader from "../components/PageHeader.astro";
import { movies } from "../lib/movies";

const allScoredMovies = movies.getWithReviews()
  .filter(m => m.isReleased)
  .sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating);
---
<MainLayout>
  <section class="pt-10 pb-20">
    <PageHeader title="Scare Scale" titleAccent="All Movies" accentColor="blood">
      <Fragment slot="description">
        View all <span class="text-blood-400">{allScoredMovies.length}</span> reviewed movies on Scare Scale.
      </Fragment>
    </PageHeader>

    <div class="max-w-screen-2xl mx-auto">
      <MovieCarouselSection
        movies={allScoredMovies}
        title="All Movies"
        carouselId="all-movies"
        mode="grid"
        eager={true}
      />
    </div>
  </section>
</MainLayout>
