---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import { SEO } from "astro-seo";
import { movies } from "../lib/movies";

const approvedMovies = movies.getApproved()
  .sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating);
---

<head>
  <meta charset="UTF-8" />
  <SEO
    title="Scare Scale Approved Horror Movies"
    description="Discover Scare Scale's top tier recommended horror movies that are truly terrifying and will keep you on the edge of your seat."
    canonical="https://scarescale.com/approved"
    openGraph={{
      basic: {
        type: "website",
        url: "https://scarescale.com/approved",
        title: "Scare Scale - Approved Horror Movies",
        image: "https://scarescale.com/screenshots/home_page_screenshot.png",
      },
      optional: {
        description:
          "Discover Scare Scale's top tier recommended horror movies that are truly terrifying and will keep you on the edge of your seat.",
      },
    }}
  />
</head>

<MainLayout>
  <section class="pt-10 pb-20">
    <header class="text-center px-6 lg:px-8 max-w-4xl mx-auto mb-12">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        Scare Scale
        <span class="block text-blood-400">Approved</span>
      </h1>
      <p class="text-xl text-gray-300 leading-relaxed">
        Our top tier recommended horror movies that are truly terrifying and will keep you on the edge of your seat.
      </p>
      <div class="w-32 h-1 bg-gradient-to-r from-blood-600 to-blood-400 mx-auto mt-8 rounded-full"></div>
    </header>

    <div class="max-w-screen-2xl mx-auto">
      <MovieCarouselSection
        movies={approvedMovies}
        title="Scare Scale Approved"
        carouselId="approved-movies"
        viewAllUrl="/all-movies"
        eager={true}
        mode="grid"
      />
    </div>
  </section>
</MainLayout>
