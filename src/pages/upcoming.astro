---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import { SEO } from "astro-seo";
import { movies } from "../lib/movies";

const upcomingMovies = movies.getUpcoming()
  .sort((a, b) => a.releaseDateParsed.getTime() - b.releaseDateParsed.getTime());
---

<head>
  <meta charset="UTF-8" />
  <SEO
    title="Scare Scale - Upcoming Horror Movies"
    description="Discover upcoming horror movies over the next 12 months. Stay updated on the latest releases in the horror genre."
    canonical="https://scarescale.com/upcoming"
    openGraph={{
      basic: {
        type: "website",
        url: "https://scarescale.com/upcoming",
        title: "Scare Scale - Upcoming Horror Movies | Release Timeline",
        image: "https://scarescale.com/screenshots/home_page_screenshot.png",
      },
      optional: {
        description:
          "Explore the timeline of upcoming horror movies. Find out what's releasing soon and plan your next scare-filled movie night.",
      },
    }}
  />
  <meta name="keywords" content="upcoming horror movies, horror releases, new horror movies, scare scale" />
</head>

<MainLayout>
  <section class="pt-10 pb-20">
    <header class="text-center px-6 lg:px-8 max-w-4xl mx-auto mb-12">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        Upcoming
        <span class="block text-blue-400">Horror Movies</span>
      </h1>
      <p class="text-xl text-gray-300 leading-relaxed">
        Horror movies to look forward to over the next 12 months.
        Stay ahead of the scares and plan your next terrifying experience.
      </p>
      <div class="w-32 h-1 bg-gradient-to-r from-blue-600 to-blue-400 mx-auto mt-8 rounded-full"></div>
    </header>

    <div class="max-w-screen-2xl mx-auto">
      <MovieCarouselSection
        movies={upcomingMovies}
        title="Coming Soon"
        carouselId="upcoming-movies"
        eager={true}
        mode="grid"
      />
    </div>
  </section>
</MainLayout>
