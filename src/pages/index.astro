---
import MainLayout from "../layouts/MainLayout.astro";
import { SEO } from "astro-seo";
import { movies } from "../lib/movies";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import FeaturedSliderSection from "../components/carousel/FeaturedSliderSection.astro";

const approvedMovies = movies.getApproved();

const featuredMovies = [...approvedMovies]
  .sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating)
  .filter(m => !!m.backdropUrl)
  .slice(0, 10);

const topMovies = [...approvedMovies]
  .sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating)
  .slice(0, 20);

const newMovies = movies.getWithReviews()
  .filter(m => m.isReleased)
  .sort((a, b) => b.releaseDateParsed.getTime() - a.releaseDateParsed.getTime())
  .slice(0, 20);

const upcomingMovies = movies.getUpcoming()
  .sort((a, b) => a.releaseDateParsed.getTime() - b.releaseDateParsed.getTime())
  .slice(0, 20);

const aiMovies = movies.getWithAiReviews()
  .sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating)
  .slice(0, 20);
---

<head>
  <meta charset="UTF-8" />
  <SEO
    title="Scare Scale - Home"
    description="Discover how scary your favorite horror movies really are with detailed ratings across Gore, Creepy, Jumpscares, Suspense, and Psychological horror categories."
    canonical="https://scarescale.com/"
    openGraph={{
      basic: {
        type: "website",
        url: "https://scarescale.com/",
        title: "Scare Scale - Horror Movie Scare Ratings | Fear Factor Breakdown",
        image: "https://scarescale.com/screenshots/home_page_screenshot.png",
      },
      optional: {
        description:
          "Rank horror movies by Gore, Creepy moments, Jumpscares, Suspense, and Psychological fear. Find the scariest films ranked by their chilling impact!",
      },
    }}
  />
  <meta
    name="keywords"
    content="horror movies, scare ratings, gore, creepy, jumpscares, suspense, psychological horror"
  />
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Scare Scale",
      "url": "https://scarescale.com/",
      "description": "Discover how scary your favorite horror movies really are with detailed ratings."
    }
  </script>
</head>

<MainLayout>
  <div class="max-w-screen-2xl mx-auto">

    {featuredMovies.length > 0 && (
      <FeaturedSliderSection movies={featuredMovies} />
    )}

    <div class="h-px bg-white/5 mx-6 mb-2"></div>

    {newMovies.length > 0 && (
      <MovieCarouselSection
        movies={newMovies}
        title="New Movies"
        carouselId="new-movies"
        viewAllUrl="/new"
      />
    )}

    <div class="h-px bg-white/5 mx-6"></div>

    {topMovies.length > 0 && (
      <MovieCarouselSection
        movies={topMovies}
        title="Top Movies"
        carouselId="top-movies"
        viewAllUrl="/approved"
        eager={true}
      />
    )}

    <div class="h-px bg-white/5 mx-6"></div>

    {upcomingMovies.length > 0 && (
      <MovieCarouselSection
        movies={upcomingMovies}
        title="Upcoming Movies"
        carouselId="upcoming-movies"
        viewAllUrl="/upcoming"
      />
    )}

    <div class="h-px bg-white/5 mx-6"></div>

    {aiMovies.length > 0 && (
      <MovieCarouselSection
        movies={aiMovies}
        title="AI Generated Reviews"
        carouselId="ai-generated"
        viewAllUrl="/ai-reviews"
      />
    )}

    <div class="py-10 flex justify-center">
      <a
        href="/all-movies"
        class="rounded-lg bg-blood-600 hover:bg-blood-700 px-8 py-3 text-sm font-semibold text-white transition-colors duration-200"
      >
        Browse All Movies →
      </a>
    </div>
  </div>
</MainLayout>
