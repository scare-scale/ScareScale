---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import PageHeader from "../components/PageHeader.astro";
import { SEO } from "astro-seo";
import { createMovies } from "../lib/movies";

const movies = await createMovies();
const aiReviewedMovies = movies.getWithAiReviews()
  .sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating);
---

<head>
  <meta charset="UTF-8" />
  <SEO
    title="Scare Scale AI Reviews"
    description="Discover Scare Scale's top tier recommended horror movies generated from Scare Scale's bespoke agentic AI agent."
    canonical="https://scarescale.com/ai-reviews"
    openGraph={{
      basic: {
        type: "website",
        url: "https://scarescale.com/ai-reviews",
        title: "Scare Scale - AI Reviews",
        image: "https://scarescale.com/screenshots/home_page_screenshot.png",
      },
      optional: {
        description:
          "Discover Scare Scale's top tier recommended horror movies generated from Scare Scale's bespoke agentic AI agent.",
      },
    }}
  />
</head>

<MainLayout>
  <section class="pt-10 pb-20">
    <PageHeader
      title="Scare Scale"
      titleAccent="AI Reviews"
      description="Take a look at our AI reviews. Generated with agentic AI, these reviews analyze the movie's plot, characters, and human reviews to provide a comprehensive assessment of its scariness."
      accentColor="blood"
    />

    <div class="max-w-screen-2xl mx-auto">
      <MovieCarouselSection
        movies={aiReviewedMovies}
        title="AI Reviewed Movies"
        carouselId="ai-reviews"
        eager={true}
        mode="grid"
      />
    </div>
  </section>
</MainLayout>
