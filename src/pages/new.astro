---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import { movies } from "../lib/movies";

const newestMovies = movies.getNewest();
---
<MainLayout>
  <section class="pt-10 pb-20">
    <header class="text-center px-6 lg:px-8 max-w-4xl mx-auto mb-12">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        Scare Scale
        <span class="block text-red-400">Recently Released Movies</span>
      </h1>
      <p class="text-xl text-gray-300 leading-relaxed">
        New horror releases worth catching on the big screen
      </p>
      <div class="w-32 h-1 bg-gradient-to-r from-red-600 to-red-400 mx-auto mt-8 rounded-full"></div>
    </header>

    <div class="max-w-screen-2xl mx-auto">
      <MovieCarouselSection
        movies={newestMovies}
        title="New Releases"
        carouselId="new-releases"
        viewAllUrl="/all-movies"
        eager={true}
      />
    </div>
  </section>
</MainLayout>
