---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import PageHeader from "../components/PageHeader.astro";
import { createMovies } from "../lib/movies";

const movies = await createMovies();
const newestMovies = movies.getNewest();
---
<MainLayout>
  <section class="pt-10 pb-20">
    <PageHeader
      title="Scare Scale"
      titleAccent="Recently Released Movies"
      description="New horror releases worth catching on the big screen."
      accentColor="blood"
    />

    <div class="max-w-screen-2xl mx-auto">
      <MovieCarouselSection
        movies={newestMovies}
        title="New Releases"
        carouselId="new-releases"
        viewAllUrl="/all-movies"
        eager={true}
        mode="grid"
      />
    </div>
  </section>
</MainLayout>
