---
import MainLayout from "../layouts/MainLayout.astro";
import MovieCarouselSection from "../components/carousel/MovieCarouselSection.astro";
import PageHeader from "../components/PageHeader.astro";
import { SEO } from "astro-seo";
import { createMovies } from "../lib/movies";

const movies = await createMovies();
const humanReviewed = movies.getWithHumanReviews().filter(m => m.isReleased);

const sections = [
  {
    title:      "All-Time Scariest",
    carouselId: "rank-all-time",
    movies:     [...humanReviewed].sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating).slice(0, 40),
  },
  {
    title:      "Scariest of 2025",
    carouselId: "rank-2025",
    movies:     [...humanReviewed].filter(m => m.releaseYear === 2025).sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating).slice(0, 40),
  },
  {
    title:      "Highest Gore",
    carouselId: "rank-gore",
    movies:     [...humanReviewed].sort((a, b) => b.getSummaryReview().categories.gore - a.getSummaryReview().categories.gore).slice(0, 40),
  },
  {
    title:      "Highest Creepy",
    carouselId: "rank-creepy",
    movies:     [...humanReviewed].sort((a, b) => b.getSummaryReview().categories.creepy - a.getSummaryReview().categories.creepy).slice(0, 40),
  },
  {
    title:      "Most Jumpscares",
    carouselId: "rank-jumpscares",
    movies:     [...humanReviewed].sort((a, b) => b.getSummaryReview().categories.jumpscares - a.getSummaryReview().categories.jumpscares).slice(0, 40),
  },
  {
    title:      "Highest Suspense",
    carouselId: "rank-suspense",
    movies:     [...humanReviewed].sort((a, b) => b.getSummaryReview().categories.suspense - a.getSummaryReview().categories.suspense).slice(0, 40),
  },
  {
    title:      "Most Psychological",
    carouselId: "rank-psychological",
    movies:     [...humanReviewed].sort((a, b) => b.getSummaryReview().categories.psychological - a.getSummaryReview().categories.psychological).slice(0, 40),
  },
  {
    title:      "Scariest 2020–2025",
    carouselId: "rank-decade",
    movies:     [...humanReviewed].filter(m => m.releaseYear >= 2020 && m.releaseYear <= 2025).sort((a, b) => b.getSummaryReview().overallRating - a.getSummaryReview().overallRating).slice(0, 40),
  },
];
---

<head>
  <meta charset="UTF-8" />
  <SEO
    title="Scare Scale - Top Horror Movie Rankings"
    description="Explore the definitive rankings of the scariest horror movies based on Gore, Creepy moments, Jumpscares, Suspense, and Psychological intensity."
    canonical="https://scarescale.com/ranks"
    openGraph={{
      basic: {
        type: "website",
        url: "https://scarescale.com/ranks",
        title: "Scare Scale - Top Horror Movie Rankings | Fear Factor Breakdown",
        image: "https://scarescale.com/screenshots/home_page_screenshot.png",
      },
      optional: {
        description:
          "Find out which horror movies rank as the scariest. From blood-curdling gore to mind-bending psychological terror, discover the top films that will haunt you.",
      },
    }}
  />
</head>

<MainLayout>
  <section class="pt-10 pb-20">
    <PageHeader
      title="Scare Scale"
      titleAccent="Rankings"
      description="Discover the most fear-inducing horror films across years and genres, ranked by our signature Scare Scale algorithm."
      accentColor="blood"
    />

    <div class="max-w-screen-2xl mx-auto flex flex-col">
      {sections.map((section, i) => section.movies.length > 0 && (
        <>
          {i > 0 && <div class="h-px bg-white/5 mx-6"></div>}
          <MovieCarouselSection
            movies={section.movies}
            title={section.title}
            carouselId={section.carouselId}
            eager={i === 0}
          />
        </>
      ))}
    </div>
  </section>
</MainLayout>
